{
    "$schema": "https://turbo.build/schema.json",
    "globalEnv": [
        "NODE_ENV"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                ".build/**",
                "dist/**"
            ],
            "env": [
                "API_BASE_URL"
            ]
        },
        "lint": {},
        "test": {
            "env": [
                "ADMIN_SECRET",
                "GEMINI_API_KEY"
            ]
        },
        "security-check": {}
    }
}