{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": [
            "node"
        ],
        "strict": false,
        "noImplicitAny": false,
        "skipLibCheck": true,
        "lib": ["ESNext", "DOM"]
    },
    "include": [
        "src/**/*",
        "scripts/**/*",
        "shared/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        ".build",
        "index.ts",
        "scripts/index.ts"
    ]

}