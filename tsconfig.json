{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "composite": false,
    "resolveJsonModule": true,
    "sourceMap": true,
    "inlineSources": true
  },
  "include": [
    "src/**/*",
    "scripts/**/*",
    "shared/**/*.ts",
    "index.ts",
    "ai-service.ts"
  ],
  "exclude": ["node_modules", ".build", "dist", ".wrangler", "scripts/index.ts"]
}
