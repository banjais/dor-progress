{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "preserve",

    "types": ["@cloudflare/workers-types"]
  },
  "include": ["**/*.ts", "index.html"],
  "exclude": ["node_modules", ".build", "dist", ".wrangler"]
}
