{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "rootDir": ".",
    "noEmit": false,
    "outDir": "../dist/shared"
  },
  "include": ["api-shared.ts"]
}