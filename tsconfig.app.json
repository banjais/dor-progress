{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "rootDir": ".",
        "lib": [
            "ESNext",
            "DOM",
            "DOM.Iterable"
        ],
        "types": [
            "vite/client"
        ]
    },
    "include": [
        "**/*.ts",
        "**/*.js",
        "global.d.ts"
    ],
    "exclude": [
        "worker.ts",
        "ai-service.ts"
    ],
    "references": [
        {
            "path": "../shared"
        }
    ]
}