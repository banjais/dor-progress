{
  "name": "dor-progress",
  "version": "1.0.438",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.ts --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "node scripts/typecheck-worker.js",
    "verify": "npm run lint && npm run typecheck",
    "clean": "rimraf dist node_modules/.vite",
    "deploy": "node scripts/deploy.js",
    "deploy:hosting": "firebase deploy --only hosting --non-interactive",
    "test": "echo \"No tests specified\" && exit 0",
    "reinstall": "rimraf node_modules package-lock.json && npm install",
    "upgrade:firebase": "npm i firebase-tools@latest firebase@latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260521.1",
    "@eslint/js": "^9.39.1",
    "@google/generative-ai": "^0.22.0",
    "@vitejs/plugin-legacy": "^7.2.1",
    "dotenv": "^17.4.2",
    "env-cmd": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "firebase": "^12.13.0",
    "firebase-tools": "^13.22.0",
    "globals": "^17.6.0",
    "jose": "^5.10.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.3",
    "terser": "^5.43.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-singlefile": "^2.3.3",
    "wrangler": "^4.93.0",
    "zod": "^3.25.76"
  },
  "overrides": {
    "ws": "^8.20.1",
    "tar": "^7.0.0",
    "uuid": "^11.0.0",
    "gaxios": "^7.0.0",
    "google-gax": "^5.0.0",
    "@google-cloud/pubsub": "^5.0.0",
    "retry-request": "^8.0.0",
    "teeny-request": "^10.0.0"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --max-warnings 0"
  },
  "engines": {
    "node": ">=22"
  }
}
