{
  "name": "dor-progress",
  "version": "1.0.108",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:worker\"",
    "build": "vite build",
    "postbuild": "node scripts/finalize-build.js",
    "deploy": "npm run clean && npm run build && npm run deploy:worker && npm run deploy:hosting && git add . && git commit -m 'Deploy' && git push",
    "deploy:worker": "wrangler deploy",
    "deploy:hosting": "firebase deploy --only hosting --public .build",
    "clean": "node scripts/clean.js",
    "lint": "tsc --noEmit",
    "test": "bash -c 'if [ -f .dev.vars ]; then while IFS= read -r line || [ -n \"$line\" ]; do if [[ \"$line\" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]]; then export \"$line\"; fi; done < .dev.vars; fi && vitest run'",
    "test:watch": "vitest",
    "version:patch": "npm version patch --no-git-tag-version && node scripts/commit-version.js",
    "version:minor": "npm version minor --no-git-tag-version && node scripts/commit-version.js",
    "version:major": "npm version major --no-git-tag-version && node scripts/commit-version.js",
    "logs": "wrangler tail --format pretty",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write",
      "bash -c 'npx tsc --build'"
    ],
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "js-tiktoken": "^1.0.17",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@eslint/js": "^10.0.1",
    "@genkit-ai/google-genai": "^1.16.1",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "concurrently": "^9.0.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-react": "^7.37.5",
    "firebase": "^12.12.1",
    "genkit": "^1.16.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jose": "^6.2.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vite-plugin-checker": "^0.13.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.0.5"
  }
}
