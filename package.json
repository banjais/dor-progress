{
  "name": "dor-progress",
  "version": "1.0.68",
  "type": "module",
  "scripts": {
    "// === DEVELOPMENT ===": "",
    "dev": "wrangler dev",
    "dev:hosting": "firebase emulators:start --only hosting",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:hosting\"",
    "// === BUILD ===": "",
    "build": "npm run compile && npm run prepublic && npm run inject && npm run build:verify",
    "compile": "tsc",
    "prepublic": "rm -rf .build && cp -r public .build",
    "inject": "node scripts/inject-env.js .build",
    "build:verify": "node scripts/verify-build.js",
    "// === DEPLOYMENT ===": "",
    "deploy": "sh deploy.sh",
    "deploy:all": "npm run deploy:worker && npm run deploy:hosting",
    "deploy:worker": "wrangler deploy",
    "deploy:hosting": "firebase deploy --only hosting --public .build",
    "deploy:only": "firebase deploy --only hosting",
    "deploy:preview": "firebase deploy --only hosting --project dor-progress",
    "deploy:prod": "sh deploy.sh",
    "deploy:live": "sh deploy.sh",
    "deploy:local": "npm run clean && npm run build && npm run deploy:all",
    "// === UTILITIES ===": "",
    "clean": "rm -rf dist .wrangler .firebase .build",
    "clean:all": "rm -rf dist .wrangler .firebase .build node_modules/.cache",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bash -c 'if [ -f .dev.vars ]; then while IFS= read -r line || [ -n \"$line\" ]; do if [[ \"$line\" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]]; then export \"$line\"; fi; done < .dev.vars; fi && vitest run'",
    "test:watch": "vitest",
    "security-check": "npm audit --audit-level=high && bash ./verify-no-secrets.sh",
    "secrets": "node scripts/check-secrets.js",
    "secrets:setup": "node scripts/setup-secrets.js",
    "// === VERSIONING ===": "",
    "version:patch": "npm version patch --no-git-tag-version && npm run version:commit",
    "version:minor": "npm version minor --no-git-tag-version && npm run version:commit",
    "version:major": "npm version major --no-git-tag-version && npm run version:commit",
    "version:commit": "node scripts/commit-version.js",
    "// === QUICK COMMANDS ===": "",
    "push": "git add . && git commit -m \"Update\" && git push",
    "status": "git status",
    "logs": "wrangler tail",
    "logs:live": "wrangler tail --format pretty",
    "info": "node scripts/project-info.js"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.17",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/node": "^20.12.7",
    "concurrently": "^9.0.0",
    "dotenv": "^17.4.2",
    "jose": "^6.2.2",
    "nodemon": "^3.1.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vitest": "^3.0.5"
  }
}
