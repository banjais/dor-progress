{
  "name": "dor-progress",
  "version": "1.0.49",
  "type": "module",
  "dependencies": {
    "js-tiktoken": "^1.0.17",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/node": "^20.12.7",
    "jose": "^6.2.2",
    "nodemon": "^3.1.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vitest": "^3.0.5"
  },
  "scripts": {
    "dev": "wrangler dev",
    "compile": "tsc",
    "deploy": "sh deploy.sh",
    "clean": "rm -rf dist .wrangler .firebase",
    "build": "sh deploy.sh",
    "types:watch": "nodemon --watch wrangler.toml --exec 'npx wrangler types'",
    "test": "bash -c 'if [ -f .dev.vars ]; then while IFS= read -r line || [ -n \"$line\" ]; do if [[ \"$line\" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]]; then export \"$line\"; fi; done < .dev.vars; fi && vitest run'",
    "lint": "tsc --noEmit",
    "security-check": "npm audit --audit-level=high && bash ./verify-no-secrets.sh",
    "test:watch": "vitest"
  }
}
