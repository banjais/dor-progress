{
  "name": "dor-progress",
  "version": "1.0.352",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --no-deprecation ./node_modules/vite/bin/vite.js",
    "build": "node --no-deprecation ./node_modules/vite/bin/vite.js build",
    "preview": "node --no-deprecation ./node_modules/vite/bin/vite.js preview",
    "lint": "node --no-deprecation ./node_modules/eslint/bin/eslint.js . --ext .js,.ts --max-warnings 0",
    "typecheck": "node --no-deprecation ./node_modules/typescript/bin/tsc --noEmit",
    "verify": "npm run lint && npm run typecheck",
    "test": "echo \"No tests specified\" && exit 0",
    "update-version": "node --no-deprecation scripts/update-version.js",
    "clean": "rimraf dist node_modules/.vite",
    "deploy:worker": "node --no-deprecation ./node_modules/wrangler/bin/wrangler.js deploy src/worker.ts",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:firebase": "firebase deploy --only hosting",
    "deploy:git": "git push --follow-tags",
    "deploy": "node --no-deprecation scripts/deploy.js",
    "audit:fix": "npm audit fix",
    "reinstall": "rimraf node_modules package-lock.json && npm install"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@eslint/js": "^9.39.1",
    "@google/generative-ai": "^0.22.0",
    "@vitejs/plugin-legacy": "^7.2.1",
    "dotenv": "^17.4.2",
    "env-cmd": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "firebase": "^12.13.0",
    "globals": "^17.6.0",
    "jose": "^5.9.6",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.3",
    "terser": "^5.43.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-singlefile": "^2.3.3",
    "wrangler": "^4.93.0",
    "zod": "^3.24.2"
  },
  "overrides": {
    "ws": "^8.20.1"
  },
  "lint-staged": {
    "*.{js,ts}": "node --no-deprecation ./node_modules/eslint/bin/eslint.js --max-warnings 0"
  },
  "engines": {
    "node": ">=20"
  }
}
