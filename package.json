{
  "name": "dor-progress",
  "version": "1.0.290",
  "type": "module",
  "scripts": {
    "dev": "node --no-deprecation ./node_modules/vite/bin/vite.js",
    "build": "node --no-deprecation ./node_modules/vite/bin/vite.js build",
    "preview": "node --no-deprecation ./node_modules/vite/bin/vite.js preview",
    "lint": "node --no-deprecation ./node_modules/eslint/bin/eslint.js . --max-warnings 0",
    "typecheck": "node --no-deprecation ./node_modules/typescript/bin/tsc --noEmit",
    "verify": "npm run lint && npm run typecheck",
    "test": "echo \"No tests specified\" && exit 0",
    "update-version": "node --no-deprecation scripts/update-version.js",
    "clean": "rimraf dist",
    "deploy:worker": "node --no-deprecation ./node_modules/wrangler/bin/wrangler.js deploy src/worker.ts --env=\"\"",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:firebase": "firebase deploy --only hosting",
    "deploy:git": "git push --follow-tags",
    "deploy": "node --no-deprecation scripts/deploy.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "jose": "^5.9.6",
    "pdf-lib": "^1.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-legacy": "^7.0.0",
    "dotenv": "^17.4.2",
    "env-cmd": "^11.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "firebase": "^12.13.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "terser": "^5.39.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.3.2",
    "wrangler": "^4.90.0"
  },
  "lint-staged": {
    "*.{js,ts}": "node --no-deprecation ./node_modules/eslint/bin/eslint.js --max-warnings 0"
  }
}
