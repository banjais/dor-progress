{
  "name": "dor-progress",
  "version": "1.0.504",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev --port 8787",
    "build": "vite build",
    "preview": "vite preview",
    "logs": "wrangler tail",
    "logs:errors": "wrangler tail --status 4xx --status 5xx --search \"error\"",
    "serve:hosting": "npm run build && firebase emulators:start --only hosting",
    "cf-typegen": "wrangler types src/worker-configuration.d.ts",
    "lint": "eslint . --fix --max-warnings 0 --no-warn-ignored",
    "typecheck": "tsc -b tsconfig.app.json",
    "typecheck:worker": "tsc -p src/tsconfig.worker.json",
    "verify": "npm run lint && tsc -b",
    "audit:check": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "prebuild": "npm run clean",
    "find-unused": "node scripts/find-unused.js",
    "clean": "rimraf dist node_modules/.vite .tsbuildinfo",
    "deploy": "node scripts/deploy.js",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "check-updates": "npx npm-check-updates",
    "test": "echo \"No tests specified\" && exit 0",
    "reinstall": "rimraf node_modules package-lock.json && npm install",
    "upgrade:firebase": "npm i firebase-tools@latest firebase@latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260528.1",
    "@eslint/js": "^9.39.1",
    "@google/generative-ai": "^0.22.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^22.19.19",
    "@vitejs/plugin-legacy": "^7.2.1",
    "dotenv": "^17.4.2",
    "env-cmd": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.8.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "firebase": "^12.13.0",
    "firebase-tools": "^13.35.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jose": "^5.10.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^5.14.0",
    "terser": "^5.48.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-singlefile": "^2.3.3",
    "wrangler": "^4.95.0",
    "xstate": "^4.38.3",
    "zod": "^3.25.76"
  },
  "overrides": {
    "ws": "^8.20.1",
    "tar": "^7.0.0",
    "uuid": "^11.0.0",
    "gaxios": "^7.0.0",
    "google-gax": "^5.0.0",
    "@google-cloud/pubsub": "^5.0.0",
    "retry-request": "^8.0.0",
    "teeny-request": "^10.0.0",
    "glob": "^11.0.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "node scripts/find-unused.js",
      "prettier --write"
    ]
  },
  "prettier": {
    "plugins": [
      "@trivago/prettier-plugin-sort-imports"
    ],
    "importOrder": [
      "^react",
      "<THIRD_PARTY_MODULES>",
      "^@/(.*)$",
      "^[./]",
      "\\.(css|scss|sass|less|png|jpg|jpeg|svg|gif|webp|woff|woff2|ttf|eot)$"
    ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true,
    "importOrderCaseInsensitive": true
  },
  "engines": {
    "node": ">=22"
  }
}
