{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,

    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["shared/*"],
      "@shared/api-shared": ["shared/api-shared.ts"]
    }
  }
}